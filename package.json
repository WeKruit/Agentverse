{
  "name": "agentverse",
  "version": "0.1.0",
  "description": "Privacy-preserving personal profile sharing between AI agents",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agentverse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "privacy",
    "verifiable-credentials",
    "bbs-signatures",
    "a2a-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@digitalbazaar/bbs-2023-cryptosuite": "^2.0.1",
    "@digitalbazaar/bbs-signatures": "^3.0.0",
    "@digitalbazaar/bls12-381-multikey": "^2.1.0",
    "@digitalbazaar/data-integrity": "^2.5.0",
    "@digitalbazaar/data-integrity-context": "^2.0.1",
    "@digitalbazaar/ed25519-multikey": "^1.3.1",
    "@digitalbazaar/vc": "^7.3.0",
    "@types/express": "^5.0.6",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "jsonld": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
