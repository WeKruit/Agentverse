{
  "name": "agentverse",
  "version": "0.1.0",
  "description": "Privacy-preserving personal profile sharing between AI agents",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agentverse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "privacy",
    "verifiable-credentials",
    "bbs-signatures",
    "a2a-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
